# PropCart Portal - Environment Variables
# Copy to .env.local and update values

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:3000

# Optional: Enable debug logging
NEXT_PUBLIC_DEBUG=false

# Optional: CDN URL for images (if using CDN instead of direct URLs)
NEXT_PUBLIC_CDN_URL=

# Optional: Google Maps API Key (for map integration)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Optional: Analytics
# NEXT_PUBLIC_GA_ID=
